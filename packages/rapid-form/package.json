{
  "name": "rapid-form",
  "version": "4.0.4",
  "private": false,
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./resolvers/zod": {
      "import": {
        "types": "./dist/resolvers/zod.d.ts",
        "default": "./dist/resolvers/zod.js"
      },
      "require": {
        "types": "./dist/resolvers/zod.d.cts",
        "default": "./dist/resolvers/zod.cjs"
      }
    },
    "./resolvers/yup": {
      "import": {
        "types": "./dist/resolvers/yup.d.ts",
        "default": "./dist/resolvers/yup.js"
      },
      "require": {
        "types": "./dist/resolvers/yup.d.cts",
        "default": "./dist/resolvers/yup.cjs"
      }
    }
  },
  "sideEffects": false,
  "description": "The best way to make a rapid form with react hooks",
  "repository": "git@github.com:Randagio13/rapid-form.git",
  "author": "Alessandro Casazza <imasterale@gmail.com>",
  "license": "MIT",
  "keywords": [
    "rapid-form",
    "react",
    "hooks",
    "form",
    "forms",
    "form-validation",
    "validation",
    "typescript",
    "react-hooks"
  ],
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsdown",
    "build:watch": "tsdown --watch"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  }
}
