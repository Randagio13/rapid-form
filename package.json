{
  "name": "root",
  "private": true,
  "author": {
    "name": "Alessandro Casazza",
    "email": "imasterale@gmail.com"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r build",
    "prepare": "husky install",
    "test": "pnpm -r test",
    "check": "biome check --write .",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "rapid-form:test": "pnpm --filter rapid-form test:dev",
    "rapid-form:test:coverage": "pnpm --filter rapid-form test:coverage",
    "rapid-form:build": "pnpm --filter rapid-form build",
    "rapid-form:watch": "pnpm --filter rapid-form build:watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "typescript": "^6.0.2"
  }
}
